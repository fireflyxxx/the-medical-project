### 0. 登录默认的系统管理员 获取 Token
POST http://localhost:8080/api/v1/account/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

> {%
    if (response.status === 200 && response.body.code === 0) {
        client.global.set("admin_token", response.body.data.token);
    }
%}

### 1. 注册账号 (管理员创建医生A)
POST http://localhost:8080/api/v1/account/create
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "username": "doctorWang",
  "password": "mySecurePassword123",
  "job_number": "100009",
  "role": "doctor"
}

### 2. 注册账号 (管理员创建医生B)
POST http://localhost:8080/api/v1/account/create
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "username": "doctor_b",
  "password": "mySecurePassword123",
  "job_number": "100002",
  "role": "doctor"
}

### 3. 登录并获取医生A的 Token
POST http://localhost:8080/api/v1/account/login
Content-Type: application/json

{
  "username": "doctor_a",
  "password": "mySecurePassword123"
}

> {%
    if (response.status === 200 && response.body.code === 0) {
        client.global.set("auth_token_a", response.body.data.token);
    }
%}

### 4. 登录并获取医生B的 Token
POST http://localhost:8080/api/v1/account/login
Content-Type: application/json

{
  "username": "doctor_b",
  "password": "mySecurePassword123"
}

> {%
    if (response.status === 200 && response.body.code === 0) {
        client.global.set("auth_token_b", response.body.data.token);
    }
%}


### 5. 医生A创建病例 (注意下划线格式符合 DTO 需要)
POST http://localhost:8080/api/v1/cases/create
Content-Type: application/json
Authorization: Bearer {{auth_token_a}}

{
  "name": "医生A的病人",
  "gender": 1,
  "age": 30,
  "id_number": "110105198001011234",
  "contact": "13800138000",
  "medical_history": "感冒",
  "case_desc": "初诊"
}

> {%
    if (response.status === 200 && response.body.code === 0) {
        client.global.set("test_case_id_a", response.body.data.case_id);
    }
%}

### 6. 医生B创建病例
POST http://localhost:8080/api/v1/cases/create
Content-Type: application/json
Authorization: Bearer {{auth_token_b}}

{
  "name": "医生B的病人",
  "gender": 0,
  "age": 25,
  "id_number": "220105198001011235",
  "contact": "13900139000",
